<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Health_Status__c</fullName>
    <externalId>false</externalId>
    <formula>IF(Average_Fleet_Efficiency__c &gt;= 0.85, 
   IMAGE(&quot;/img/samples/light_green.gif&quot;, &quot;Healthy&quot;, 20, 20),
   IF(Average_Fleet_Efficiency__c &gt;= 0.70, 
      IMAGE(&quot;/img/samples/light_yellow.gif&quot;, &quot;Warning&quot;, 20, 20),
      IMAGE(&quot;/img/samples/light_red.gif&quot;, &quot;Critical&quot;, 20, 20)
   )
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Health Status</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
